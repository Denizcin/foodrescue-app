# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# Neon: Dashboard → Project → Connection string (use "Pooled connection")
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Or: https://generate-secret.vercel.app/32
AUTH_SECRET="your-32-byte-random-secret-here"

# ─── iyzico Payment ───────────────────────────────────────────────────────────
# Sandbox: https://sandbox-merchant.iyzipay.com  →  Settings → API Keys
# Production: https://merchant.iyzipay.com       →  Settings → API Keys
IYZICO_API_KEY="sandbox-your-api-key"
IYZICO_SECRET_KEY="sandbox-your-secret-key"

# Sandbox:    https://sandbox-api.iyzipay.com
# Production: https://api.iyzipay.com
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com → API Keys → Create API Key
# Optional — if not set, email notifications are silently skipped.
RESEND_API_KEY="re_your_api_key_here"

# Verified sender address in your Resend account
# Format: "Name <email@yourdomain.com>"
EMAIL_FROM="FoodRescue <noreply@yourdomain.com>"

# ─── App URL ──────────────────────────────────────────────────────────────────
# Must match your Vercel deployment URL exactly (no trailing slash)
# iyzico uses this for payment callback redirect
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
